# Copy to .env.local (gitignored) and fill in real values for local dev.
# On your deploy platform (Vercel/Netlify/etc.), set these as environment variables.

# API Keys
VITE_CLAUDE_API_KEY=your_claude_api_key_here

# OpenRouter API key for the AI ChatWidget (src/components/ChatWidget.tsx).
# Without it, the chat widget renders but cannot send messages.
VITE_OPENROUTER_API_KEY=

# Example:
# VITE_CLAUDE_API_KEY=sk-ant-api03-...